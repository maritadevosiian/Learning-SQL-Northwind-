/* Author: Mari
Description: A comprehensive collection of SQL queries for Northwind database analysis, 
ranging from basic joins to complex analytical reporting.
*/

-- 1. Get all product names and their corresponding supplier company names
SELECT P.ProductName, S.CompanyName
FROM Products AS P
INNER JOIN Suppliers AS S ON P.SupplierID = S.SupplierID;

-- 2. List products along with their category names
SELECT P.ProductName, C.CategoryName
FROM Products AS P
INNER JOIN Categories AS C ON P.CategoryID = C.CategoryID;

-- 3. Display Order IDs and the names of the customers who placed them
SELECT O.OrderID, C.CompanyName
FROM Orders AS O
INNER JOIN Customers AS C ON O.CustomerID = C.CustomerID;

-- 4. Show Order IDs and the employees who handled each order
SELECT O.OrderID, E.FirstName, E.LastName
FROM Orders AS O
INNER JOIN Employees AS E ON O.EmployeeID = E.EmployeeID;

-- 5. List Order IDs and the shipping companies used for delivery
SELECT O.OrderID, S.CompanyName
FROM Orders AS O
INNER JOIN Shippers AS S ON O.ShipVia = S.ShipperID;

-- 6. Filter orders that were shipped specifically to 'London'
SELECT O.OrderID, C.CompanyName
FROM Orders AS O
INNER JOIN Customers AS C ON O.CustomerID = C.CustomerID
WHERE O.ShipCity = 'London';

-- 7. Triple Join: Retrieve Order ID, Customer Name, and Employee Last Name
SELECT O.OrderID, C.CompanyName, E.LastName
FROM Orders AS O
JOIN Customers AS C ON O.CustomerID = C.CustomerID
JOIN Employees AS E ON O.EmployeeID = E.EmployeeID;

-- 8. Count the number of products in each category (Aggregations)
SELECT C.CategoryName, COUNT(P.ProductID) AS ProductCount
FROM Categories AS C
JOIN Products AS P ON C.CategoryID = P.CategoryID
GROUP BY C.CategoryName;

-- 9. Calculate the total price for each line item in orders (Quantity * UnitPrice)
SELECT O.OrderID, P.ProductName, 
       (OD.Quantity * OD.UnitPrice) AS TotalPrice
FROM [Order Details] AS OD
JOIN Products AS P ON OD.ProductID = P.ProductID
JOIN Orders AS O ON OD.OrderID = O.OrderID;

-- 10. List all employees and their orders, including those with no orders (LEFT JOIN)
SELECT E.FirstName, E.LastName, O.OrderID
FROM Employees AS E
LEFT JOIN Orders AS O ON E.EmployeeID = O.EmployeeID;

-- 11. Calculate total spending for each customer (Revenue per Customer)
SELECT C.CompanyName, SUM(OD.Quantity * OD.UnitPrice) AS TotalSpend
FROM Customers AS C
JOIN Orders AS O ON C.CustomerID = O.CustomerID
JOIN [Order Details] AS OD ON O.OrderID = OD.OrderID
GROUP BY C.CompanyName;

-- 12. Self-Join: List employees and the names of their direct managers
SELECT A.FirstName AS Employee, B.FirstName AS Manager
FROM Employees AS A
INNER JOIN Employees AS B ON A.ReportsTo = B.EmployeeID;

-- 13. Find suppliers that provide more than 3 different products (HAVING clause)
SELECT S.CompanyName, COUNT(P.ProductID) AS CountOfProducts
FROM Suppliers AS S
JOIN Products AS P ON S.SupplierID = P.SupplierID
GROUP BY S.CompanyName
HAVING COUNT(P.ProductID) > 3;

-- 14. Retrieve all product names ordered by the customer 'Vinet et Alcool'
SELECT DISTINCT P.ProductName
FROM Customers AS C
JOIN Orders AS O ON C.CustomerID = O.CustomerID
JOIN [Order Details] AS OD ON O.OrderID = OD.OrderID
JOIN Products AS P ON OD.ProductID = P.ProductID
WHERE C.CompanyName = 'Vinet et Alcool';

-- 15. Total quantity of 'Beverages' sold by each employee (Multi-table join)
SELECT E.FirstName + ' ' + E.LastName AS EmployeeName, SUM(OD.Quantity) AS TotalQty
FROM Employees AS E
JOIN Orders AS O ON E.EmployeeID = O.EmployeeID
JOIN [Order Details] AS OD ON O.OrderID = OD.OrderID
JOIN Products AS P ON OD.ProductID = P.ProductID
JOIN Categories AS C ON P.CategoryID = C.CategoryID
WHERE C.CategoryName = 'Beverages'
GROUP BY E.FirstName + ' ' + E.LastName;
